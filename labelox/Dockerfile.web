FROM python:3.11-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1-mesa-glx libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

# Python deps
COPY labelox/requirements-web.txt /app/requirements-web.txt
COPY labelox/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements-web.txt

# App code
COPY . /app

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

CMD ["uvicorn", "labelox.web.backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
